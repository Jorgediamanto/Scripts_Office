{"version":"0.3.0","body":"function main(workbook: ExcelScript.Workbook) {\n    const ws = workbook.getWorksheets()[0];\n\n    const used = ws.getUsedRange();\n    if (!used) return;\n\n    const rowCount = used.getRowCount();\n    const colCount = used.getColumnCount();\n\n    // 1) Leer SOLO cabeceras (fila 1)\n    const headers = ws.getRangeByIndexes(0, 0, 1, colCount).getValues()[0]\n        .map(v => (v ?? \"\").toString().trim());\n\n    const blCol = headers.indexOf(\"Business Line\");\n    const pvCol = headers.indexOf(\"Project Valor\");\n    if (blCol === -1 || pvCol === -1) {\n        throw new Error(`No encuentro cabeceras. BL=${blCol}, PV=${pvCol}`);\n    }\n\n    // 2) Procesar por bloques para no superar límites\n    const CHUNK = 5000; // si aún diera problemas baja a 2000\n    // Recorremos desde abajo hacia arriba para poder borrar\n    for (let chunkEnd = rowCount - 1; chunkEnd >= 1; chunkEnd -= CHUNK) {\n        const chunkStart = Math.max(1, chunkEnd - CHUNK + 1);\n        const chunkRows = chunkEnd - chunkStart + 1;\n\n        // Leer SOLO las 2 columnas necesarias en este bloque\n        const blVals = ws.getRangeByIndexes(chunkStart, blCol, chunkRows, 1).getValues();\n        const pvVals = ws.getRangeByIndexes(chunkStart, pvCol, chunkRows, 1).getValues();\n\n        // Marcar filas a borrar dentro del chunk (índice local 0..chunkRows-1)\n        const del: boolean[] = new Array(chunkRows).fill(false);\n        for (let i = 0; i < chunkRows; i++) {\n            const bl = (blVals[i][0] ?? \"\").toString().trim();\n            const pv = (pvVals[i][0] ?? \"\").toString().trim().toUpperCase();\n            if (bl === \"59000\" || pv === \"GA2767\") del[i] = true;\n        }\n\n        // 3) Borrar en bloques contiguos (dentro del chunk), desde abajo\n        let i = chunkRows - 1;\n        while (i >= 0) {\n            if (!del[i]) { i--; continue; }\n\n            let endLocal = i;\n            let startLocal = i;\n            while (startLoca